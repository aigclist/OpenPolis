NEXT_PUBLIC_APP_URL=http://localhost:3000
OPENPOLIS_APP_URL=http://localhost:3000
OPENPOLIS_ALLOWED_ORIGIN_HOSTS=localhost:3000,127.0.0.1:3000

# Local workflow actor bootstrap for self-hosted and demo environments.
OPENPOLIS_ACTOR_TYPE=human
OPENPOLIS_ACTOR_ID=operator_central
OPENPOLIS_ACTOR_ROLE=central_ops
OPENPOLIS_ACTOR_TEAM_ID=team_central_ops
OPENPOLIS_ACTOR_REGION_ID=north_network

# Accept JSON ActorRef overrides from x-openpolis-actor or openpolis_actor.
# Keep this off outside local development until a real auth/session layer exists.
OPENPOLIS_ALLOW_ACTOR_OVERRIDE=false

# Better Auth-backed operator session configuration. Once both values are configured,
# protected workspace routes require a real operator account and first-run onboarding
# happens from /settings instead of using a shared bootstrap password.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000
