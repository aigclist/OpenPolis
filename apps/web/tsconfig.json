{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@openpolis/application": ["../../packages/application/src/index.ts"],
      "@openpolis/application/*": ["../../packages/application/src/*"],
      "@openpolis/contracts": ["../../packages/contracts/src/index.ts"],
      "@openpolis/contracts/*": ["../../packages/contracts/src/*"],
      "@openpolis/governance": ["../../packages/governance/src/index.ts"],
      "@openpolis/governance/*": ["../../packages/governance/src/*"],
      "@openpolis/runtime": ["../../packages/runtime/src/index.ts"],
      "@openpolis/runtime/*": ["../../packages/runtime/src/*"],
      "@openpolis/db": ["../../packages/db/src/index.ts"],
      "@openpolis/db/*": ["../../packages/db/src/*"],
      "@openpolis/i18n/*": ["../../packages/i18n/src/*"],
      "@openpolis/domain": ["../../packages/domain/src/index.ts"],
      "@openpolis/domain/*": ["../../packages/domain/src/*"],
      "@openpolis/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "src/components/ai-elements/**/*.tsx"
  ]
}
